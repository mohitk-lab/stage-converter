{
  "functions": {
    "api/convert.js": { "maxDuration": 60 },
    "api/stem-separate.js": { "maxDuration": 30 },
    "api/stem-status.js": { "maxDuration": 10 },
    "api/transcribe.js": { "maxDuration": 60 },
    "api/clone-voice.js": { "maxDuration": 60 },
    "api/upload-url.js": { "maxDuration": 10 },
    "api/tts.js": { "maxDuration": 30 },
    "api/voices.js": { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
